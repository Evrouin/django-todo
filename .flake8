[flake8]
max-line-length = 100
exclude = 
    .git,
    __pycache__,
    venv,
    env,
    .venv,
    migrations,
    staticfiles,
    media,
    logs,
    .pytest_cache,
    htmlcov,
    *.egg-info
max-complexity = 10
ignore = E203,E501,W503,E402
per-file-ignores =
    __init__.py:F401
    */settings/*.py:E501,F403,F405
